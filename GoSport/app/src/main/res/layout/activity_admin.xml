<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary_dark_green"
            android:elevation="4dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:title="Admin Dashboard"
            app:titleTextColor="@color/white" />

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- Left Menu (Navigation Drawer) -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true">

        <!-- Header Profile Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@color/primary_dark_green"
            android:padding="20dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/profileCard"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_centerVertical="true"
                app:cardCornerRadius="35dp"
                app:cardElevation="4dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/sym_def_app_icon"
                    android:padding="10dp"/>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="15dp"
                android:layout_toEndOf="@id/profileCard"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAdminName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quản trị viên"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="admin@gosport.com"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Menu Items -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Item Quản lý User -->
                <LinearLayout
                    android:id="@+id/btnUser"
                    style="@style/AdminMenuItemStyle"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">
                    <ImageView style="@style/AdminMenuIconStyle" android:src="@android:drawable/ic_menu_myplaces" />
                    <TextView style="@style/AdminMenuTextStyle" android:text="Quản lý User" />
                </LinearLayout>

                <!-- Item Danh mục -->
                <LinearLayout
                    android:id="@+id/btnCategory"
                    style="@style/AdminMenuItemStyle"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">
                    <ImageView style="@style/AdminMenuIconStyle" android:src="@android:drawable/ic_menu_sort_by_size" />
                    <TextView style="@style/AdminMenuTextStyle" android:text="Danh mục" />
                </LinearLayout>

                <!-- Item Quản lý Sân -->
                <LinearLayout
                    android:id="@+id/btnField"
                    style="@style/AdminMenuItemStyle"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">
                    <ImageView style="@style/AdminMenuIconStyle" android:src="@android:drawable/ic_dialog_map" />
                    <TextView style="@style/AdminMenuTextStyle" android:text="Quản lý Sân" />
                </LinearLayout>

                <!-- Item Đơn đặt -->
                <LinearLayout
                    android:id="@+id/btnBooking"
                    style="@style/AdminMenuItemStyle"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">
                    <ImageView style="@style/AdminMenuIconStyle" android:src="@android:drawable/ic_menu_agenda" />
                    <TextView style="@style/AdminMenuTextStyle" android:text="Đơn đặt sân" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="10dp"
                    android:background="#EEEEEE" />

                <!-- Item Báo cáo -->
                <LinearLayout
                    android:id="@+id/btnReport"
                    style="@style/AdminMenuItemStyle"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">
                    <ImageView style="@style/AdminMenuIconStyle" android:src="@android:drawable/ic_menu_report_image" />
                    <TextView style="@style/AdminMenuTextStyle" android:text="Báo cáo thống kê" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnLogout"
                    style="@style/AdminMenuItemStyle"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <ImageView
                        style="@style/AdminMenuIconStyle"
                        android:src="@android:drawable/ic_lock_power_off" />

                    <TextView
                        style="@style/AdminMenuTextStyle"
                        android:text="Đăng xuất" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>