<?xml version="1.0" encoding="utf-8"?>
<!-- item_order_admin.xml — dùng trong RecyclerView của Admin -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1B5E20"
            android:paddingHorizontal="14dp"
            android:paddingVertical="9dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvAdminOrderCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#ORD-20250115-004"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <!-- Status Chip -->
            <TextView
                android:id="@+id/tvAdminOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chờ duyệt"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp" />

        </LinearLayout>

        <!-- Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <!-- Customer Info Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:tint="#A5D6A7"
                    android:background="#E8F5E9"
                    android:padding="4dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="10dp">

                    <TextView
                        android:id="@+id/tvCustomerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nguyễn Văn An"
                        android:textColor="#212121"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCustomerPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0901 234 567"
                        android:textColor="#757575"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Price -->
                <TextView
                    android:id="@+id/tvAdminPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="150.000đ"
                    android:textColor="#1B5E20"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0"
                android:layout_marginBottom="8dp" />

            <!-- Service Info -->
            <TextView
                android:id="@+id/tvAdminServiceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sân cầu lông A - Buổi sáng"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Date -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    app:tint="#388E3C"
                    android:layout_gravity="center_vertical" />

                <TextView
                    android:id="@+id/tvAdminDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="15/01/2025"
                    android:textColor="#424242"
                    android:textSize="12sp"
                    android:paddingStart="5dp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    app:tint="#388E3C"
                    android:layout_gravity="center_vertical" />

                <TextView
                    android:id="@+id/tvAdminTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="07:00 - 09:00"
                    android:textColor="#424242"
                    android:textSize="12sp"
                    android:paddingStart="5dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ========== ACTION BUTTONS (Admin Only) ========== -->
        <LinearLayout
            android:id="@+id/layoutAdminActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingBottom="12dp"
            android:paddingTop="8dp">

            <!-- CHECK-IN Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckIn"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Check-in"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#0277BD"
                app:iconTint="#FFFFFF"
                app:iconSize="16dp"
                app:iconPadding="4dp"
                app:cornerRadius="6dp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button" />

            <!-- COMPLETE Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnComplete"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Hoàn thành"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#2E7D32"
                app:iconTint="#FFFFFF"
                app:iconSize="16dp"
                app:iconPadding="4dp"
                app:cornerRadius="6dp"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>

        <!-- Completed / Cancelled overlay state (GONE by default, show when needed) -->
        <LinearLayout
            android:id="@+id/layoutCompletedState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#E8F5E9"
            android:paddingVertical="10px"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                app:tint="#2E7D32" />

            <TextView
                android:id="@+id/tvCompletedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đơn đã hoàn thành"
                android:textColor="#2E7D32"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingStart="6dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>