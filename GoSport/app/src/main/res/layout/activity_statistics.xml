<?xml version="1.0" encoding="utf-8"?>
<!-- activity_statistics.xml -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <!-- ===== APP BAR ===== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:elevation="0dp"
        android:background="#1B5E20">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1B5E20"
            app:title="Báo cáo thống kê"
            app:titleTextColor="#FFFFFF"
            app:navigationIconTint="#FFFFFF">

            <!-- Export Button -->
            <ImageView
                android:id="@+id/ivExport"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:tint="#FFFFFF"
                android:padding="6dp"
                android:layout_gravity="end"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Xuất báo cáo" />

        </com.google.android.material.appbar.MaterialToolbar>

        <!-- Year Selector Strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#2E7D32"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivPrevYear"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:tint="#A5D6A7"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp" />

            <LinearLayout
                android:id="@+id/btnFilterTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/tvSelectedYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tháng 03, 2026"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:drawablePadding="8dp"
                    app:drawableTint="#FFFFFF" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivNextYear"
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:tint="#A5D6A7"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp" />

        </LinearLayout>

        <!-- Tab: Đơn đặt / Doanh thu -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutReport"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="#1B5E20"
            app:tabTextColor="#A5D6A7"
            app:tabSelectedTextColor="#FFFFFF"
            app:tabIndicatorColor="#69F0AE"
            app:tabIndicatorHeight="3dp"
            app:tabGravity="fill"
            app:tabMode="fixed">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Số lượng đơn" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Doanh thu" />

        </com.google.android.material.tabs.TabLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ===== SCROLLABLE CONTENT ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ===== KPI SUMMARY CARDS ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="14dp"
                android:paddingBottom="4dp">

                <!-- Card: Tổng đơn năm -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#1B5E20">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            app:tint="#A5D6A7"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvTotalOrdersYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="248"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng đơn"
                            android:textColor="#A5D6A7"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                        <!-- Growth indicator -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                app:tint="#69F0AE" />


                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card: Doanh thu năm -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            app:tint="#1B5E20"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvTotalRevenueYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="37.2tr"
                            android:textColor="#1B5E20"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Doanh thu (VNĐ)"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                app:tint="#2E7D32" />


                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Second row KPI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="4dp">

                <!-- Card: Tháng cao nhất -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏆 Tháng cao nhất"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tvBestMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tháng 8"
                            android:textColor="#1B5E20"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvBestMonthOrders"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="32 đơn • 5.6tr VNĐ"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card: Trung bình/tháng -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊 Trung bình/tháng"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tvAvgOrders"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="20.7 đơn"
                            android:textColor="#1B5E20"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvAvgRevenue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3.1tr VNĐ / tháng"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ===== BAR CHART: SỐ LƯỢNG ĐƠN ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardOrderChart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Chart Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="18dp"
                            android:background="#1B5E20" />

                        <TextView
                            android:id="@+id/tvOrderHeader"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Số lượng đơn đặt theo tháng"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingStart="10dp" />

                        <!-- Legend -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="#1B5E20" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" Đơn"
                                android:textColor="#757575"
                                android:textSize="11sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!--                    <TextView-->
                    <!--                        android:layout_width="wrap_content"-->
                    <!--                        android:layout_height="wrap_content"-->
                    <!--                        android:text="Năm 2025 • Tổng 248 đơn"-->
                    <!--                        android:textColor="#9E9E9E"-->
                    <!--                        android:textSize="11sp"-->
                    <!--                        android:paddingStart="14dp"-->
                    <!--                        android:layout_marginBottom="12dp" />-->


                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginVertical="12dp" />

                    <!-- Monthly Mini Table -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chi tiết từng tháng"
                        android:textColor="#424242"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Header Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="28dp"
                        android:orientation="horizontal"
                        android:background="#E8F5E9"
                        android:paddingHorizontal="8dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tháng"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:text="Số đơn"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Tỉ lệ"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="end" />

                    </LinearLayout>

                    <!-- RecyclerView for monthly table rows -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerMonthlyOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== BAR CHART: DOANH THU ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardRevenueChart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Chart Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="18dp"
                            android:background="#388E3C" />

                        <TextView
                            android:id="@+id/tvRevenueHeader"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Doanh thu theo tháng"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingStart="10dp" />

                    </LinearLayout>


                    <!-- MPAndroidChart BarChart: Doanh thu -->
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChartRevenue"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginVertical="12dp" />

                    <!-- Monthly Revenue Table Header -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chi tiết doanh thu"
                        android:textColor="#424242"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="28dp"
                        android:orientation="horizontal"
                        android:background="#E8F5E9"
                        android:paddingHorizontal="8dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tháng"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Doanh thu"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:text="Tăng trưởng"
                            android:textColor="#2E7D32"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="end" />

                    </LinearLayout>

                    <!-- RecyclerView for monthly revenue rows -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerMonthlyRevenue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== COMBO CHART (Line + Bar) — Tỉ lệ hoàn thành ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCompletionChart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="18dp"
                            android:background="#69F0AE" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Tỉ lệ hoàn thành đơn theo tháng"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingStart="10dp" />

                    </LinearLayout>

                    <!-- Legend Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:layout_marginBottom="10dp">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="#1B5E20"
                            android:layout_gravity="center_vertical" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" Hoàn thành"
                            android:textColor="#757575"
                            android:textSize="11sp" />

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="#F57F17"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" Hủy"
                            android:textColor="#757575"
                            android:textSize="11sp" />

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="#0277BD"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" Đang xử lý"
                            android:textColor="#757575"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChartStatus"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />


                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>