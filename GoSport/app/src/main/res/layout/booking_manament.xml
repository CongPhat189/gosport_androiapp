<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:elevation="6dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1B5E20"
            app:title="Đơn đặt của tôi"
            app:titleTextColor="#FFFFFF"
            app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"

            app:navigationIconTint="#FFFFFF" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Filter Bar -->
        <LinearLayout
            android:id="@+id/layoutFilterBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:gravity="center_vertical"
            android:elevation="4dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:tint="#1B5E20" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lọc theo thời gian"
                android:textColor="#388E3C"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="8dp" />

            <!-- Filter Chips -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Tất cả"
                    android:textSize="12sp"
                    app:chipStrokeColor="#1B5E20"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconTint="#FFFFFF"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Tháng này"
                    android:textSize="12sp"
                    app:chipStrokeColor="#1B5E20"
                    app:chipStrokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Chip.Filter" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCustom"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Tùy chọn"
                    android:textSize="12sp"
                    app:chipStrokeColor="#1B5E20"
                    app:chipStrokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Chip.Filter" />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

        <!-- Date Range Display (visible when custom selected) -->
        <LinearLayout
            android:id="@+id/layoutDateRange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#E8F5E9"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                app:tint="#2E7D32" />

            <TextView
                android:id="@+id/tvDateRangeFrom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/01/2025"
                android:textColor="#1B5E20"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" → "
                android:textColor="#4CAF50"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvDateRangeTo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="31/12/2025"
                android:textColor="#1B5E20"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvChangeDateRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thay đổi"
                android:textColor="#388E3C"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="8dp" />

        </LinearLayout>

        <!-- Summary Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp">

            <!-- Tổng đơn -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="10dp"
                android:layout_marginEnd="6dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/tvTotalOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textColor="#1B5E20"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tổng đơn"
                    android:textColor="#757575"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Chờ xác nhận -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="10dp"
                android:layout_marginEnd="6dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/tvPendingOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="#F57F17"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chờ duyệt"
                    android:textColor="#757575"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Hoàn thành -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="10dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/tvCompletedOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9"
                    android:textColor="#2E7D32"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoàn thành"
                    android:textColor="#757575"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewOrders"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false"
            android:scrollbars="none" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:tint="#C8E6C9"
                android:alpha="0.7" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có đơn đặt nào"
                android:textColor="#9E9E9E"
                android:textSize="16sp"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Các đơn của bạn sẽ hiển thị ở đây"
                android:textColor="#BDBDBD"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>