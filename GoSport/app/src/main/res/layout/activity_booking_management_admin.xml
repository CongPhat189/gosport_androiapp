<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <!-- AppBar with Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:elevation="0dp"
        android:background="#1B5E20">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1B5E20"
            app:title="Quản lý đơn đặt"
            app:titleTextColor="#FFFFFF"
            app:navigationIconTint="#FFFFFF">

            <ImageView
                android:id="@+id/ivFilterIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:tint="#FFFFFF"
                android:padding="6dp"
                android:layout_gravity="end"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Lọc" />

        </com.google.android.material.appbar.MaterialToolbar>

        <!-- Date Filter Strip -->
        <LinearLayout
            android:id="@+id/layoutDateStrip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#2E7D32"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickDateFrom"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Từ: DD/MM/YYYY"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                app:iconTint="#A5D6A7"
                app:iconSize="14dp"
                app:iconPadding="4dp"
                app:strokeColor="#A5D6A7"
                app:strokeWidth="1dp"
                android:backgroundTint="#00000000"
                app:cornerRadius="4dp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickDateTo"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Đến:DD/MM/YYYY"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                app:iconTint="#A5D6A7"
                app:iconSize="14dp"
                app:iconPadding="4dp"
                app:strokeColor="#A5D6A7"
                app:strokeWidth="1dp"
                android:backgroundTint="#00000000"
                app:cornerRadius="4dp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApplyFilter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Lọc"
                android:textColor="#1B5E20"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#A5D6A7"
                app:cornerRadius="4dp"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>

        <!-- Tab Layout for Status Filter -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutStatus"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="#1B5E20"
            app:tabTextColor="#A5D6A7"
            app:tabSelectedTextColor="#FFFFFF"
            app:tabIndicatorColor="#69F0AE"
            app:tabIndicatorHeight="3dp"
            app:tabMode="scrollable"
            >

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tất cả" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chờ duyệt" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã Check-in" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoàn thành" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã hủy" />

        </com.google.android.material.tabs.TabLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Stats Summary Row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Card: Tổng -->
                <androidx.cardview.widget.CardView
                    android:layout_width="90dp"
                    android:layout_height="70dp"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvStatTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24"
                            android:textColor="#1B5E20"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card: Chờ duyệt -->
                <androidx.cardview.widget.CardView
                    android:layout_width="90dp"
                    android:layout_height="70dp"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvStatPending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5"
                            android:textColor="#F57F17"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chờ duyệt"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card: Check-in -->
                <androidx.cardview.widget.CardView
                    android:layout_width="90dp"
                    android:layout_height="70dp"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvStatCheckedIn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7"
                            android:textColor="#0277BD"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Check-in"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card: Hoàn thành -->
                <androidx.cardview.widget.CardView
                    android:layout_width="90dp"
                    android:layout_height="70dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvStatCompleted"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12"
                            android:textColor="#2E7D32"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hoàn thành"
                            android:textColor="#9E9E9E"
                            android:textSize="10sp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </HorizontalScrollView>

        <!-- RecyclerView Admin Orders -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewAdminOrders"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false"
            android:scrollbars="none" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmptyAdmin"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:tint="#C8E6C9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Không có đơn nào"
                android:textColor="#9E9E9E"
                android:textSize="15sp"
                android:layout_marginTop="12dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>