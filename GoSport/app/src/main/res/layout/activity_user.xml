<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary_dark_green"
            android:elevation="4dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:title="GoSport"
            app:titleTextColor="@color/white" />

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- Drawer -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@color/primary_dark_green"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Người dùng"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/btnViewField"
                style="@style/AdminMenuItemStyle"
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <ImageView
                    style="@style/AdminMenuIconStyle"
                    android:src="@android:drawable/ic_dialog_map"/>

                <TextView
                    style="@style/AdminMenuTextStyle"
                    android:text="Xem sân"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnProfile"
                style="@style/AdminMenuItemStyle"
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <ImageView
                    style="@style/AdminMenuIconStyle"
                    android:src="@android:drawable/ic_menu_myplaces"/>

                <TextView
                    style="@style/AdminMenuTextStyle"
                    android:text="Thông tin cá nhân"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnFielded"
                style="@style/AdminMenuItemStyle"
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <ImageView
                    style="@style/AdminMenuIconStyle"
                    android:src="@android:drawable/ic_menu_myplaces"/>

                <TextView
                    style="@style/AdminMenuTextStyle"
                    android:text="Sân đã đặt"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnLogout"
                style="@style/AdminMenuItemStyle"
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <ImageView
                    style="@style/AdminMenuIconStyle"
                    android:src="@android:drawable/ic_lock_power_off"/>

                <TextView
                    style="@style/AdminMenuTextStyle"
                    android:text="Đăng xuất"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>