            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPayBank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#F1F8E9"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#4CAF50"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_calendar" app:tint="#455A64"/>
